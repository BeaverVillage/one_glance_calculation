# 한눈계산 주차비 계산 지도 환경변수 예시
# 실제 API Key를 저장소에 커밋하지 마세요. Cloudflare Pages 환경변수/Secrets에 등록하세요.

# 1차 MVP 필수: 카카오 지도 JavaScript SDK 표시용 키입니다.
# JavaScript 키는 브라우저에 노출될 수 있는 키이지만, 반드시 Kakao Developers에서 Web 플랫폼 도메인 제한을 걸어야 합니다.
KAKAO_MAP_JS_KEY=

# 선택 또는 향후 확장: REST API Key는 프론트엔드에 직접 노출하지 마세요.
# Cloudflare Pages Functions 또는 Worker proxy에서만 사용하세요.
KAKAO_REST_API_KEY=
KAKAO_MOBILITY_API_KEY=
KAKAO_MOBILITY_API_BASE=https://apis-navi.kakaomobility.com
KAKAO_MOBILITY_DESTINATIONS_PATH=/v1/destinations/directions
KAKAO_MOBILITY_RADIUS_METERS=5000
KAKAO_MOBILITY_CACHE_TTL_SECONDS=120
PUBLIC_DATA_API_KEY=
PUBLIC_DATA_PARKING_API_URL=
SEOUL_OPEN_API_KEY=
SEOUL_OPEN_API_BASE=http://openapi.seoul.go.kr:8088
HOLIDAY_API_KEY=
HOLIDAY_API_BASE=https://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService
HOLIDAY_API_NAME=getRestDeInfo
HOLIDAY_API_CACHE_TTL_SECONDS=86400

# Kakao Developers 도메인 등록 안내
# Kakao Developers > 내 애플리케이션 > 앱 설정 > 플랫폼 > Web 플랫폼에 아래 도메인을 등록해야 합니다.
# - https://hannuncalc.com
# - Cloudflare Pages 기본 도메인
# - 로컬 테스트 도메인 예: http://localhost:8788, http://localhost:5173, http://localhost:8000

# 2차 MVP 데이터 어댑터
# SEOUL_OPEN_API_KEY가 있으면 서울시 공영주차장 안내 정보(GetParkInfo)를 Functions에서 조회할 수 있습니다.
# PUBLIC_DATA_PARKING_API_URL은 공공데이터포털 주차장 API endpoint를 직접 지정할 때만 사용합니다.
#
# 정적 배포에서 Functions를 쓰지 않는 경우
# assets/config/public-config.js를 배포 환경에서 생성하거나 대체해 공개 가능한 KAKAO_MAP_JS_KEY만 주입할 수 있습니다.
# REST API Key는 public-config.js에 넣지 마세요.

# 2차 후속 MVP: 서울 실시간 주차대수 adapter
# 기본 서비스명은 서울 열린데이터의 GetParkingInfo 샘플 URL 구조를 따르며, 실제 계정/서비스 설정이 다르면 아래 값으로 덮어쓸 수 있습니다.
SEOUL_REALTIME_PARKING_API_NAME=GetParkingInfo
PARKING_API_CACHE_TTL_SECONDS=300
PARKING_REALTIME_CACHE_TTL_SECONDS=60

# 3차 후속 MVP: 공휴일/운영시간 판정
# HOLIDAY_API_KEY가 있으면 한국천문연구원 특일 정보(getRestDeInfo)를 Functions에서 조회해
# 평일/토요일/공휴일 운영시간 판정에 반영합니다. 키가 없으면 토요일·일요일 기준 fallback으로 동작합니다.
# 데이터 출처: 공공데이터포털 한국천문연구원_특일 정보


# 4차 후속 MVP: Kakao Mobility 차량 소요시간 proxy
# KAKAO_MOBILITY_API_KEY 또는 KAKAO_REST_API_KEY가 있으면 Functions에서만 Kakao Mobility 다중 목적지 길찾기를 호출해
# 출발지에서 주차장 후보까지의 차량 소요시간과 거리를 추천점수에 반영합니다.
# 이 키는 브라우저에 노출하지 마세요.
