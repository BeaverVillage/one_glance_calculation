# 한눈계산 주차비 계산 지도 MVP 환경변수 예시
# 실제 API Key를 저장소에 커밋하지 마세요. Cloudflare Pages 환경변수/Secrets에 등록하세요.

# 카카오맵 JavaScript API: 지도 표시, 목적지/주차장 마커, 지도 중심 이동
# JavaScript Key는 브라우저에 노출될 수 있으므로 Kakao Developers Web 플랫폼 도메인 제한을 반드시 설정하세요.
KAKAO_MAP_JS_KEY=

# 카카오 Local API: 목적지 검색, 주소/장소명 -> 좌표 변환
# REST API Key는 프론트엔드에 직접 노출하지 말고 Cloudflare Pages Functions에서만 사용하세요.
KAKAO_REST_API_KEY=

# 공공데이터포털 전국주차장정보표준데이터 또는 특일 정보 API 호출용
PUBLIC_DATA_API_KEY=

# 서울 열린데이터: 공영주차장 안내 정보와 시영주차장 실시간 주차대수 정보 조회용
SEOUL_OPEN_API_KEY=

# 한국천문연구원 특일 정보 공휴일 판정용. 없으면 토요일/일요일 기준 fallback으로 동작합니다.
HOLIDAY_API_KEY=

# Kakao Developers 도메인 등록 안내
# Kakao Developers > 내 애플리케이션 > 앱 설정 > 플랫폼 > Web 플랫폼에 아래 도메인을 등록해야 합니다.
# - https://hannuncalc.com
# - https://www.hannuncalc.com
# - Cloudflare Pages 기본 도메인
# - 로컬 테스트 도메인 예: http://localhost:3000, http://localhost:5173, http://localhost:8788

# 이번 MVP는 지도 표시, 목적지 검색, 주차비 계산, 실시간 빈자리 참고 표시만 다룹니다.
# 외부 경로 API, 자동차 이동시간, 이동거리, 유류비, 통행료 계산용 키는 사용하지 않습니다.
