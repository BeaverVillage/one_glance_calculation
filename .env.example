# Cloudflare Pages > Settings > Environment variables 에 등록하세요.
# 공공데이터포털 일반 인증키를 넣으세요. 일부 API는 Encoding/Decoding 구분 없이 일반 인증키 1개만 표시됩니다.

# 국세청 사업자등록정보 API와 공정위 통신판매사업자 API를 같은 공공데이터포털 키로 사용할 경우
DATA_GO_KR_SERVICE_KEY=

# API별로 분리하고 싶을 경우 아래 변수 사용
NTS_SERVICE_KEY=
FTC_SERVICE_KEY=

# 선택: 추후 Turnstile을 붙일 때 사용할 수 있습니다. 현재 v2에서는 사용하지 않습니다.
TURNSTILE_SECRET_KEY=

# v18 전기차 충전소 지도 / 미세먼지·외출 체크
KAKAO_MAP_JS_KEY=
KAKAO_REST_API_KEY=
EV_CHARGER_API_KEY=
AIRKOREA_API_KEY=
KMA_API_KEY=
# 위 공공데이터포털 API들이 같은 키를 쓰면 DATA_GO_KR_SERVICE_KEY 하나만 등록해도 됩니다.
